mixin button--contained(options)
  button(
    class=[
      "flex cursor-pointer justify-center items-center px-3 py-1 border border-transparent text-sm leading-4 font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-color sm:w-auto",
      options.fullWidth ? "w-full" : ""
    ].join(' ')
    id=options.id
    type=options.type
  )
    div(class="htmx-indicator-hide flex items-center justify-center w-full h-full")
      block
    div(class="absolute mx-auto my-auto")
      div(class="htmx-indicator text-white")
        include ../svg/button-loader.pug
