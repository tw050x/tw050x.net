mixin form-field--text--read(options)
  div(
    class="read-field-container"
    id=`${options.id}-container`
  )
    div(class="flex items-center justify-between mb-2")
      label(
        for=`${options.id}-input`
        class="text-sm font-medium text-gray-900"
      ) #{options.label}
    div
      div(class="w-full p-3 bg-gray-200 rounded-md cursor-not-allowed text-base h-12 flex items-center") #{options.value}
      div(class="flex items-center justify-between mt-3")
        div(class="flex space-x-2")
          a(
            class="inline-flex items-center px-3 py-1 border border-transparent text-sm leading-4 font-medium rounded-lg text-blue-700 bg-blue-100 hover:bg-blue-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
            href=options.endpoint
            hx-get=options.endpoint
            hx-target=`#${options.id}-container`
            hx-swap="outerHTML"
            id=`${options.id}-edit-button`
          )
            svg(class="w-4 h-4 mr-1", fill="none", stroke="currentColor", viewBox="0 0 24 24")
              path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z")
            | Edit
