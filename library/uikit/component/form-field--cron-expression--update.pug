mixin form-field--cron-expression--update(options)
  - var initialValues = (options.initialValue || '0 0 * * *').split(' ')
  div(
    class="update-field-container"
    id=`${options.id}-container`
  )
    div(class="flex items-center justify-between mb-2")
      label(
        class="text-sm font-medium text-gray-900"
      ) #{options.label}
      div(
        class="htmx-indicator text-xs font-medium text-blue-600 bg-blue-50 px-2 rounded-md border border-blue-200"
        id=`${options.id}-saving-indicator`
      )
        svg(class="w-3 h-3 mr-1 inline animate-spin", fill="none", stroke="currentColor", viewBox="0 0 24 24")
          path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15")
        | Saving...
      div(
        class="htmx-indicator text-xs font-medium text-red-600 bg-blue-50 px-2 rounded-md border border-blue-200"
        id=`${options.id}-cancelling-indicator`
      )
        svg(class="w-3 h-3 mr-1 inline animate-spin", fill="none", stroke="currentColor", viewBox="0 0 24 24")
          path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15")
        | Cancelling...

    form(
      action=options.endpoint
      method="post"
      hx-disabled-elt=`this, #${options.id}-save-button, #${options.id}-cancel-button`
      hx-ext="response-targets"
      hx-indicator=`#${options.id}-saving-indicator`
      hx-patch=options.endpoint
      hx-swap="outerHTML"
      hx-target=`#${options.id}-container`
      id=`${options.id}-form`
    )
      div(class="grid grid-cols-5 gap-3")
        div(class="text-center")
          label(
            for=`${options.id}-minute`
            class="block text-xs font-medium text-gray-700 mb-1"
          ) Minute
          input(
            class=[
              "w-full p-2 rounded-md font-mono text-sm text-center",
              "focus:ring-blue-500",
              options.errors && options.errors.length > 0 ? "bg-red-100" : "bg-gray-200"
            ].join(' ')
            id=`${options.id}-minute`
            name=`schedule-minute`
            placeholder="*"
            type="text"
            value=initialValues[0] || '*'
            onchange=`updateCronExpression('${options.id}', 'schedule')`
          )
          div(class="text-xs text-gray-500 mt-1") 0-59

        div(class="text-center")
          label(
            for=`${options.id}-hour`
            class="block text-xs font-medium text-gray-700 mb-1"
          ) Hour
          input(
            class=[
              "w-full p-2 rounded-md font-mono text-sm text-center",
              "focus:ring-blue-500",
              options.errors && options.errors.length > 0 ? "bg-red-100" : "bg-gray-200"
            ].join(' ')
            id=`${options.id}-hour`
            name=`schedule-hour`
            placeholder="*"
            type="text"
            value=initialValues[1] || '*'
            onchange=`updateCronExpression('${options.id}', 'schedule')`
          )
          div(class="text-xs text-gray-500 mt-1") 0-23

        div(class="text-center")
          label(
            for=`${options.id}-day`
            class="block text-xs font-medium text-gray-700 mb-1"
          ) Day
          input(
            class=[
              "w-full p-2 rounded-md font-mono text-sm text-center",
              "focus:ring-blue-500",
              options.errors && options.errors.length > 0 ? "bg-red-100" : "bg-gray-200"
            ].join(' ')
            id=`${options.id}-day`
            name=`schedule-day`
            placeholder="*"
            type="text"
            value=initialValues[2] || '*'
            onchange=`updateCronExpression('${options.id}', 'schedule')`
          )
          div(class="text-xs text-gray-500 mt-1") 1-31

        div(class="text-center")
          label(
            for=`${options.id}-month`
            class="block text-xs font-medium text-gray-700 mb-1"
          ) Month
          input(
            class=[
              "w-full p-2 rounded-md font-mono text-sm text-center",
              "focus:ring-blue-500",
              options.errors && options.errors.length > 0 ? "bg-red-100" : "bg-gray-200"
            ].join(' ')
            id=`${options.id}-month`
            name=`schedule-month`
            placeholder="*"
            type="text"
            value=initialValues[3] || '*'
            onchange=`updateCronExpression('${options.id}', 'schedule')`
          )
          div(class="text-xs text-gray-500 mt-1") 1-12

        div(class="text-center")
          label(
            for=`${options.id}-weekday`
            class="block text-xs font-medium text-gray-700 mb-1"
          ) Weekday
          input(
            class=[
              "w-full p-2 rounded-md font-mono text-sm text-center",
              "focus:ring-blue-500",
              options.errors && options.errors.length > 0 ? "bg-red-100" : "bg-gray-200"
            ].join(' ')
            id=`${options.id}-weekday`
            name=`schedule-weekday`
            placeholder="*"
            type="text"
            value=initialValues[4] || '*'
            onchange=`updateCronExpression('${options.id}', 'schedule')`
          )
          div(class="text-xs text-gray-500 mt-1") 0-6

      script.
        function updateCronExpression(id, inputName) {
          // This function can be used for validation or other purposes
          // Individual inputs will be sent separately to the server
        }

      if options.errors && options.errors.length > 0
        include ./notice--contained--error
        div(class="mt-2")
          +notice--contained--error()
            if options.errors.length === 1
              | #{options.errors[0]}
            else
              div The following errors occurred:
              ul(class="list-disc list-inside space-y-1 mt-2 ml-4")
                each error in options.errors
                  li #{error}

      div(class="flex items-center justify-between mt-3")
        div(class="flex space-x-2")
          include ./button--contained
          +button--contained({
            id: `${options.id}-save-button`,
          })
            include ../svg/check.pug
            | Save
          a(
            class="inline-flex items-center px-3 py-1 border border-gray-300 text-sm leading-4 font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
            href=options.endpoint
            hx-disabled-elt=`this, #${options.id}-save-button, #${options.id}-cancel-button`
            hx-ext="response-targets"
            hx-get=options.endpoint
            hx-indicator=`#${options.id}-cancelling-indicator`
            hx-swap="outerHTML"
            hx-target=`#${options.id}-container`
            id=`${options.id}-cancel-button`
          )
            svg(class="w-4 h-4 mr-1", fill="none", stroke="currentColor", viewBox="0 0 24 24")
              path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M6 18L18 6M6 6l12 12")
            | Cancel
