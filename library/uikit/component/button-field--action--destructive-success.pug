mixin button-field--action--destructive-success(options)
  div(
    id=`${options.id}-container`
  )
    div(class="flex flex-row items-center justify-between")
      span(class="text-sm font-medium text-gray-900") #{options.label}
      div(class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-medium text-orange-700 bg-orange-50 border border-orange-200")
        svg(class="w-3 h-3 mr-1.5", fill="none", stroke="currentColor", viewBox="0 0 24 24")
          path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z")
        | #{options.infoText}
