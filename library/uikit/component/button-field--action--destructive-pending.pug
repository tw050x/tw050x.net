mixin button-field--action--destructive-pending(options)
  div(
    id=`${options.id}-container`
  )
    div(class="flex flex-row items-center justify-between")
      span(class="text-sm font-medium text-gray-900") #{options.label}
      div(class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-medium text-orange-700 bg-orange-50 border border-orange-200")
        svg(class="w-3 h-3 mr-1.5", fill="none", stroke="currentColor", viewBox="0 0 24 24")
          path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z")
        | #{options.infoText}
    div(class="flex flex-row gap-2 justify-end mt-4")
      div(
        class="flex items-center"
        id=`${options.forceId}-container`
      )
        div(
          class="htmx-indicator hidden text-xs font-medium text-blue-600 bg-blue-50 px-2 py-1 rounded-md border border-blue-200"
          id=`${options.forceId}-processing-indicator`
        )
          svg(class="w-3 h-3 mr-1 inline animate-spin", fill="none", stroke="currentColor", viewBox="0 0 24 24")
            path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15")
          | Processing...
        button(
          class="bg-red-600 hover:bg-red-700 text-white font-medium py-1.5 px-3 rounded-lg text-xs inline-flex items-center border border-red-600 hover:border-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-all duration-200"
          hx-disabled-elt=`this, #${options.id}-container`
          hx-ext="response-targets"
          hx-indicator=`#${options.forceId}-processing-indicator`
          hx-confirm=options.forceConfirmText
          hx-delete=options.forceEndpoint
          hx-swap="outerHTML"
          hx-target=`#${options.id}-container`
          id=`${options.forceId}-button`
          type="button"
        )
          svg(class="w-3 h-3 mr-1.5", fill="none", stroke="currentColor", viewBox="0 0 24 24")
            path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1-1H8a1 1 0 00-1 1v3M4 7h16")
          | #{options.forceText}
      form(
        class="flex items-center"
        hx-disabled-elt=`this, #${options.id}-container`
        hx-ext="response-targets"
        hx-indicator=`#${options.undoId}-processing-indicator`
        hx-confirm=options.undoConfirmText
        hx-patch=options.undoEndpoint
        hx-swap="outerHTML"
        hx-target=`#${options.id}-container`
        id=`${options.undoId}-form`
      )
        input(
          name=options.undoFormInputName
          type="hidden"
          value="false"
        )
        div(
          class="htmx-indicator hidden text-xs font-medium text-blue-600 bg-blue-50 px-2 py-1 rounded-md border border-blue-200"
          id=`${options.undoId}-processing-indicator`
        )
          svg(class="w-3 h-3 mr-1 inline animate-spin", fill="none", stroke="currentColor", viewBox="0 0 24 24")
            path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15")
          | Processing...
        button(
          class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-1.5 px-3 rounded-lg text-xs inline-flex items-center border border-blue-600 hover:border-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all duration-200"
          type="submit"
        )
          svg(class="w-3 h-3 mr-1.5", fill="none", stroke="currentColor", viewBox="0 0 24 24")
            path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6")
          | #{options.undoText}
