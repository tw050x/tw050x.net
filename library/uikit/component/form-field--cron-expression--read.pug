mixin form-field--cron-expression--read(options)
  - var cronParts = (options.value || '0 0 * * *').split(' ')
  div(
    class="read-field-container"
    id=`${options.id}-container`
  )
    div(class="flex items-center justify-between mb-2")
      label(
        class="text-sm font-medium text-gray-900"
      ) #{options.label}

    div(class="grid grid-cols-5 gap-3")
      div(class="text-center")
        div(class="text-xs font-medium text-gray-700 mb-1") Minute
        div(class="p-2 bg-gray-200 rounded-md font-mono text-sm text-center") #{cronParts[0] || '*'}
        div(class="text-xs text-gray-500 mt-1") 0-59

      div(class="text-center")
        div(class="text-xs font-medium text-gray-700 mb-1") Hour
        div(class="p-2 bg-gray-200 rounded-md font-mono text-sm text-center") #{cronParts[1] || '*'}
        div(class="text-xs text-gray-500 mt-1") 0-23

      div(class="text-center")
        div(class="text-xs font-medium text-gray-700 mb-1") Day
        div(class="p-2 bg-gray-200 rounded-md font-mono text-sm text-center") #{cronParts[2] || '*'}
        div(class="text-xs text-gray-500 mt-1") 1-31

      div(class="text-center")
        div(class="text-xs font-medium text-gray-700 mb-1") Month
        div(class="p-2 bg-gray-200 rounded-md font-mono text-sm text-center") #{cronParts[3] || '*'}
        div(class="text-xs text-gray-500 mt-1") 1-12

      div(class="text-center")
        div(class="text-xs font-medium text-gray-700 mb-1") Weekday
        div(class="p-2 bg-gray-200 rounded-md font-mono text-sm text-center") #{cronParts[4] || '*'}
        div(class="text-xs text-gray-500 mt-1") 0-6

    div(class="flex items-center justify-between mt-3")
      div(class="flex space-x-2")
        a(
          class="inline-flex items-center px-3 py-1 border border-transparent text-sm leading-4 font-medium rounded-lg text-blue-700 bg-blue-100 hover:bg-blue-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
          href=options.endpoint
          hx-get=options.endpoint
          hx-target=`#${options.id}-container`
          hx-swap="outerHTML"
          id=`${options.id}-edit-button`
        )
          svg(class="w-4 h-4 mr-1", fill="none", stroke="currentColor", viewBox="0 0 24 24")
            path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z")
          | Edit
