doctype html
html(lang="en")
  head
    base(href="/")
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title Forbidden

    include ../partial/htmx
    include ../partial/stylesheet
  body
    div(class="flex flex-col px-8 pt-8")
      h1(class="text-4xl") Forbidden
      div(class="flex flex-col py-8 space-y-4")
          div(class="flex flex-col")
            h2(class="text-xl font-semibold") You do not have permission to access this resource.
            span
              | You should navigate somewhere else, or&nbsp;
              a(href="javascript:history.back()", class="text-blue-500 underline mt-8") go back.
