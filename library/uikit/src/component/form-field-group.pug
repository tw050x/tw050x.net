mixin form-field-group(options = {})
  div(
    class=[
      options.hideBorder === true ? '' : 'border border-gray-300',
      'overflow-hidden',
      'rounded-lg',
    ].join(' ')
  )
    div(
      class=[
        'flex flex-col space-y-8',
        options.hideBorder === true ? '' : 'p-4',
        options.separater === true ? '[&>*:not(:first-child)]:border-t [&>*:not(:first-child)]:border-t-gray-300 [&>*]:border-b-0' : ''
      ].join(' ')
    )
      block
