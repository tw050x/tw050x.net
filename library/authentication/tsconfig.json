    "outDir": "./artifact",
    "rootDir": "./src",
    "types": [
      "@kitajs/html/htmx.d.ts",
      "@types/node",
    ],
  },
  "exclude": [
    "artifact"
  ],
  "extends": "../../tsconfig.json",
  "files": [
    "src/middleware/use-access-token-cookie.tsx",
    "src/middleware/use-login-state-cookie.tsx",
    "src/middleware/use-refresh-token-cookie.tsx",
    "src/middleware/use-refreshable-token-cookie.tsx",
    "src/oauth2/provider/apple/authorisation-url.ts",
    "src/oauth2/provider/apple/exchange-code-for-token.ts",
    "src/oauth2/provider/apple/fetch-user-profile.ts",
    "src/oauth2/provider/azure/authorisation-url.ts",
    "src/oauth2/provider/azure/exchange-code-for-token.ts",
    "src/oauth2/provider/azure/fetch-user-profile.ts",
    "src/oauth2/provider/facebook/authorisation-url.ts",
    "src/oauth2/provider/facebook/exchange-code-for-token.ts",
    "src/oauth2/provider/facebook/fetch-user-profile.ts",
    "src/oauth2/provider/google/authorisation-url.ts",
    "src/oauth2/provider/google/exchange-code-for-token.ts",
    "src/oauth2/provider/google/fetch-user-profile.ts",
    "src/oauth2/provider/x/authorisation-url.ts",
    "src/oauth2/provider/x/exchange-code-for-token.ts",
    "src/oauth2/provider/x/fetch-user-profile.ts",
