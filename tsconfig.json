{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@kitajs/html",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "plugins": [
      { "name": "@kitajs/ts-html-plugin" }
    ],
    "sourceMap": true,
    "strict": true,
    "target": "ES2024",
  },
  "exclude": [
    ".vscode/",
    ".yarn/",
    "container/",
    "coverage/",
    "cypress/",
    "documentation/",
    "log/",
    "playground/",
    "tmp/",
  ],
  "files": [],
  "references": [
    { "path": "./cypress" },
    { "path": "./library/database" },
    { "path": "./library/platform" },
    { "path": "./library/static" },
    { "path": "./service/authorisation" },
    { "path": "./service/error" },
    { "path": "./service/marketing" },
    { "path": "./service/navigation" },
    { "path": "./service/payment" },
    { "path": "./service/portal" },
    { "path": "./service/user" },
    { "path": "./tool/certificate" },
    { "path": "./tool/migrate" },
    { "path": "./worker/sessions-queue" },
    { "path": "./worker/user-queue" },
  ]
}
