{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@kitajs/html",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "plugins": [
      { "name": "@kitajs/ts-html-plugin" }
    ],
    "strict": true,
    "target": "es2024",
  },
  "exclude": [
    ".vscode/",
    ".yarn/",
    "container/",
    "coverage/",
    "documentation/",
    "log/",
    "node_modules/",
    "playground/",
    "tmp/"
  ],
  "files": [],
  "references": [
    { "path": "./library/database" },
    { "path": "./library/logger" },
    { "path": "./library/middleware" },
    { "path": "./library/service" },
    { "path": "./library/uikit" },
    { "path": "./library/utility" },
    { "path": "./service/administration" },
    { "path": "./service/authentication" },
    { "path": "./service/error" },
    { "path": "./service/marketing" },
    { "path": "./service/navigation" },
    { "path": "./service/user" }
  ]
}
