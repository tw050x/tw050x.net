{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@kitajs/html",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "plugins": [
      { "name": "@kitajs/ts-html-plugin" }
    ],
    "strict": true,
    "target": "es2024",
  },
  "exclude": [
    ".vscode/",
    ".yarn/",
    "container/",
    "coverage/",
    "documentation/",
    "log/",
    "playground/",
    "tmp/"
  ],
  "files": [],
  "references": [
    { "path": "./database/authentication-database" },
    { "path": "./library/database-library" },
    { "path": "./library/logger-library" },
    { "path": "./library/middleware-library" },
    { "path": "./library/service-library" },
    { "path": "./library/uikit-library" },
    { "path": "./library/utility-library" },
    { "path": "./service/administration-service" },
    { "path": "./service/assets-service" },
    { "path": "./service/authentication-service" },
    { "path": "./service/error-service" },
    { "path": "./service/marketing-service" },
    { "path": "./service/navigation-service" },
    { "path": "./service/user-service" }
  ]
}
