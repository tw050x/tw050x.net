{
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mongo.addConnection",
        "icon": "$(add)",
        "title": "Add Connection"
      },
      {
        "command": "mongo.searchDocuments",
        "icon": "$(search)",
        "title": "Search"
      },
      {
        "command": "mongo.clearSearchDocuments",
        "icon": "$(clear-all)",
        "title": "Clear Search"
      },
      {
        "command": "mongo.connectToConnection",
        "icon": "$(plug)",
        "title": "Connect"
      },
      {
        "command": "mongo.editConnection",
        "icon": "$(edit)",
        "title": "Edit Connection"
      },
      {
        "command": "mongo.deleteConnection",
        "icon": "$(trash)",
        "title": "Delete Connection"
      },
      {
        "command": "mongo.refresh",
        "icon": "$(refresh)",
        "title": "Refresh"
      },
      {
        "command": "mongo.openDocument",
        "icon": "$(go-to-file)",
        "title": "Open Document"
      },
      {
        "command": "mongo.insertDocument",
        "icon": "$(new-file)",
        "title": "Insert Document"
      },
      {
        "command": "mongo.deleteDocument",
        "icon": "$(trash)",
        "title": "Delete Document"
      },
      {
        "command": "mongo.showMetadata",
        "icon": "$(info)",
        "title": "Show Metadata"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "mongo.searchDocuments",
          "when": "false"
        },
        {
          "command": "mongo.clearSearchDocuments",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "mongo.connectToConnection",
          "group": "inline",
          "when": "view == mongoExplorer && viewItem == connection"
        },
        {
          "command": "mongo.editConnection",
          "group": "inline",
          "when": "view == mongoExplorer && viewItem == connection"
        },
        {
          "command": "mongo.deleteConnection",
          "group": "inline",
          "when": "view == mongoExplorer && viewItem == connection"
        },
        {
          "command": "mongo.showMetadata",
          "group": "inline",
          "when": "view == mongoExplorer && (viewItem == database || viewItem == collection || viewItem == document)"
        },
        {
          "command": "mongo.searchDocuments",
          "group": "inline@10",
          "when": "view == mongoExplorer && viewItem == collection"
        },
        {
          "command": "mongo.clearSearchDocuments",
          "group": "inline@11",
          "when": "view == mongoExplorer && viewItem == collection"
        },
        {
          "command": "mongo.insertDocument",
          "group": "inline",
          "when": "view == mongoExplorer && viewItem == collection"
        },
        {
          "command": "mongo.openDocument",
          "group": "inline",
          "when": "view == mongoExplorer && viewItem == document"
        },
        {
          "command": "mongo.deleteDocument",
          "group": "inline",
          "when": "view == mongoExplorer && viewItem == document"
        }
      ],
      "view/title": [
        {
          "command": "mongo.addConnection",
          "group": "navigation",
          "when": "view == mongoExplorer"
        },
        {
          "command": "mongo.searchDocuments",
          "group": "navigation@10",
          "when": "view == mongoExplorer"
        },
        {
          "command": "mongo.clearSearchDocuments",
          "group": "navigation@11",
          "when": "view == mongoExplorer"
        },
        {
          "command": "mongo.refresh",
          "group": "navigation",
          "when": "view == mongoExplorer"
        }
      ]
    },
    "views": {
      "mongo-explorer": [
        {
          "id": "mongoExplorer",
          "name": "Explorer"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "icon": "media/mongo-activitybar.svg",
          "id": "mongo-explorer",
          "title": "Mongo"
        }
      ]
    }
  },
  "description": "A simple MongoDB client for VS Code",
  "displayName": "@tw050x.net.extension/mongo",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./src/extension.js",
  "name": "@tw050x.net.extension/mongo",
  "publisher": "tw050x",
  "version": "0.0.1"
}
